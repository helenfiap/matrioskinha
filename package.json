{
  "name": "matrioskinha-app2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.app.json && tsc --noEmit --incremental false -p tsconfig.node.json",
    "lint": "oxlint",
    "preview": "vite preview",
    "validate:content": "tsx scripts/validate-content.ts",
    "migrate:content": "tsx scripts/migrate-content.ts",
    "audio:plan": "tsx scripts/audio-batch.ts plan",
    "audio:generate": "tsx scripts/audio-batch.ts generate",
    "audio:verify": "tsx scripts/audio-batch.ts verify",
    "art:moods": "powershell -ExecutionPolicy Bypass -File scripts/generate-emotion-moods.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "npm run validate:content && npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "check:all": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
